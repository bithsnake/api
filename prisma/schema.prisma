generator client {
  provider     = "prisma-client-js"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

/*
  Recommended cardinality:
  - Appointment -> Billing: 1:1
  - Appointment -> ReminderNotification: 1:N
  - Appointment -> UserEventLog: 1:N
  - Patient -> Appointment: 1:N (normal real-world model)
*/
model Appointment {
  id          Int   @id @default(autoincrement())
  date        DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  patientId     Int
  patient       Patient  @relation(fields: [patientId], references: [id])

  userId     Int
  user       User     @relation(fields: [userId], references: [id])

  billing     Billing?
  reminders   ReminderNotification[]
  eventLogs   UserEventLog[]
}

model Patient {
  id          Int           @id @default(autoincrement())
  name        String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  email       String        @unique

  appointments Appointment[]
}

model Billing {
  id            Int      @id @default(autoincrement())
  appointmentId Int         @unique
  amount        Float
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
}

model ReminderNotification {
  id            Int      @id @default(autoincrement())
  appointmentId Int
  message       String
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@index([appointmentId])
}

model UserEventLog {
  id            Int      @id @default(autoincrement())
  appointmentId Int
  event         String
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@index([appointmentId])
}

model User {
  id               Int             @id @default(autoincrement())
  email            String          @unique
  name             String?
  firstName        String?
  lastName         String?
  role             Role            @default(DENTIST)
  specializationId Int?
  specialization   Specialization? @relation(fields: [specializationId], references: [id])
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  appointments Appointment[]
}


model Specialization {
  id        Int                 @id @default(autoincrement())
  name      String              @unique
  type      SpecializationType?
  users     User[]
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt
}


enum Role {
  ADMIN
  DENTIST
  RECEPTIONIST
  NEW
}


enum AppointmentStatus {
  SCHEDULED
  COMPLETED
  CANCELED
}

enum NotificationType {
  EMAIL
  SMS
}

enum EventType {
  CREATED
  UPDATED
  CANCELED
}

enum SpecializationType {
  ORTHODONTICS
  ENDODONTICS
  PERIODONTICS
  PROSTHODONTICS
  PEDIATRIC_DENTISTRY
}