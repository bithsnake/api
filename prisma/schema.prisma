generator client {
  provider     = "prisma-client-js"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model Appointment {
  id        Int      @id @default(autoincrement())
  name      String
  type      AppointmentType @default(CHECKUP)
  date      DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  patientId Int
  patient   Patient @relation(fields: [patientId], references: [id])

  userId Int
  user   User @relation(fields: [userId], references: [id])

  billing   Billing?
  reminders Reminder[]
  eventLogs AppointmentEventLog[]

  status AppointmentStatus @default(SCHEDULED)
}

model Patient {
  id        Int      @id @default(autoincrement())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  email     String   @unique

  appointments Appointment[]
}

model Billing {
  id            Int      @id @default(autoincrement())
  appointmentId Int      @unique
  amount        Float
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  status BillingStatus @default(DRAFT)

  description String?

  eventLogs BillingEventLog[]
}

model Reminder {
  id            Int      @id @default(autoincrement())
  appointmentId Int
  message       String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  eventLogs ReminderEventLog[]

  @@index([appointmentId])
}
model User {
  id               Int             @id @default(autoincrement())
  email            String          @unique
  name             String?
  firstName        String?
  lastName         String?
  role             Role            @default(DENTIST)
  specializationId Int?
  specialization   Specialization? @relation(fields: [specializationId], references: [id])
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  appointments Appointment[]

  eventLogs UserEventLog[]

  @@index([specializationId])
}

model Specialization {
  id        Int                 @id @default(autoincrement())
  name      String              @unique
  type      SpecializationType?
  users     User[]
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt
}

// event logs
model AppointmentEventLog {
  id            Int       @id @default(autoincrement())
  appointmentId Int
  eventType     EventType @default(CREATED)
  event         String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@index([appointmentId])
}

model BillingEventLog {
  id        Int       @id @default(autoincrement())
  billingId Int
  eventType EventType @default(CREATED)
  event     String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  billing Billing @relation(fields: [billingId], references: [id], onDelete: Cascade)

  @@index([billingId])
}

model ReminderEventLog {
  id         Int       @id @default(autoincrement())
  reminderId Int
  eventType  EventType @default(CREATED)
  event      String
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  reminder Reminder @relation(fields: [reminderId], references: [id], onDelete: Cascade)

  @@index([reminderId])
}

model UserEventLog {
  id        Int       @id @default(autoincrement())
  userId    Int?      
  eventType EventType @default(CREATED)
  event     String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

enum EventType {
  CREATED
  UPDATED
  CANCELED
  REMINDER
  DELETED
}

enum Role {
  ADMIN
  DENTIST
  RECEPTIONIST
  NEW
  PATIENT
}

enum AppointmentStatus {
  SCHEDULED
  ONGOING
  COMPLETED
  CANCELED
  DELETED
}

enum AppointmentType {
  CHECKUP
  FOLLOW_UP
  CONSULTATION
  CLEANING
  FILLING
  EXTRACTION
  ROOT_CANAL
  ORTHODONTIC
  PERIODONTAL
  PROSTHODONTIC
  PEDIATRIC
  EMERGENCY
  OTHER
}

enum BillingStatus {
  DRAFT
  INVOICED
  PAID
  CANCELED
  DELETED
  OVERDUE
}

enum NotificationType {
  EMAIL
  SMS
}

enum ReminderStatus {
  PENDING
  SENT
  FAILED
}

enum ReminderType {
  APPOINTMENT_REMINDER
  USER_REMINDER
  BILLING_REMINDER
}

enum SpecializationType {
  ORTHODONTICS
  ENDODONTICS
  PERIODONTICS
  PROSTHODONTICS
  PEDIATRIC_DENTISTRY
}
