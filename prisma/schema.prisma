generator client {
  provider     = "prisma-client-js"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int   @id @default(autoincrement())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  specialization String?
}

model Appointment {
  id        String   @id @default(cuid())
  date      DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}